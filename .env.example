# ── Base de datos ────────────────────────────────────────────────
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_db"

# ── JWT ──────────────────────────────────────────────────────────
# Cambia estos valores en producción (mínimo 32 caracteres random)
JWT_SECRET="utec_rate_secret_super_seguro_cambiar_en_produccion_2025"
JWT_REFRESH_SECRET="utec_rate_refresh_secret_super_seguro_cambiar_2025"

# ── Servidor ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────
# En producción poner la URL del frontend
CORS_ORIGIN="http://localhost:5173"
